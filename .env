# Thresholds
KGY_CPU_THRESHOLD=80
KGY_MEMORY_THRESHOLD=80
KGY_DISK_THRESHOLD=90
KGY_LOAD_THRESHOLD=4.0

# Email Alerts
KGY_EMAIL_ALERTS=true
KGY_ALERT_EMAIL=admin@yourcompany.com

# Slack Alerts
KGY_SLACK_ALERTS=true
KGY_SLACK_WEBHOOK=https://hooks.slack.com/services/xxx/yyy/zzz

# Telegram Alerts
KGY_TELEGRAM_ALERTS=true
KGY_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
KGY_TELEGRAM_CHAT_ID=-123456789

# Dashboard Security
KGY_DASHBOARD_SECRET=your-secret-key-here
KGY_ALLOWED_IPS=127.0.0.1,192.168.1.100

# Log Settings
KGY_LOG_RETENTION=30